{
  "layer": "top",
  "position": "top",
  "height": 30,

  "modules-left": ["sway/workspaces", "sway/mode"],
  "modules-center": ["clock"],
  "modules-right": ["cpu", "memory", "network", "pulseaudio", "battery", "tray"],

  "clock": {
    "format": "{:%H:%M | %d.%m}"
  },

  "battery": {
    "format": "{capacity}% {icon}",
    "states": {
      "warning": 30,
      "critical": 15
    }
  },

  "pulseaudio": {
    "format": " {volume}%"
  },

  "cpu": {
    "format": "CPU {usage}%"
  },

  "memory": {
    "format": "RAM {percentage}%"
  },

  "network": {
    "format-wifi": " {essid}",
    "format-ethernet": " {ipaddr}",
    "format-disconnected": "✖ No Net",
    "tooltip-format": "Signal: {signalStrength}%",
    "on-click": "~/.config/sway/scripts/wifi-menu.sh"
}}
